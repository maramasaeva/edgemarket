# Polymarket Trading Bot Configuration
# Copy to .env and fill in your values

# Wallet (REQUIRED)
PRIVATE_KEY=0x_your_private_key_here
# SAFE_ADDRESS=0x_your_safe_address_if_using_proxy_wallet

# Polymarket CLOB
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137

# Trading Parameters
DRY_RUN=true
BANKROLL=100
MIN_BET=1.0
MAX_BET=10.0
MIN_EDGE=0.02
KELLY_FRACTION=0.25

# Strategy
STRATEGY=arb
# Options: arb, momentum, market_maker, convergence, all

# Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=INFO
